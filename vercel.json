{
  "buildCommand": "echo 'Static site'",
  "outputDirectory": "public",
  "public": true,
  "headers": [
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "text/css" }
      ]
    }
  ]
}
